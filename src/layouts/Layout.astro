---
import TheNavbar from "~/components/TheNavbar.astro";
import BaseLayout from "./Base.astro";
import type { ComponentProps } from "astro/types";
import TheFooter from "~/components/TheFooter.astro";

// eslint-disable-next-line @typescript-eslint/no-empty-object-type
interface Props extends ComponentProps<typeof BaseLayout> {}

const { class: className, "class:list": classList, ...props } = Astro.props;
---

<BaseLayout
  {...props}
  class:list={[
    "font-space-grotesk grid grid-rows-[auto_1fr_auto] bg-linear-to-br from-slate-800 via-slate-900 to-neutral-600 bg-fixed text-lg leading-6 text-white",
    classList,
    className,
  ]}
>
  <slot name="head" slot="head" />

  <slot name="navbar">
    <TheNavbar />
  </slot>

  <main>
    <slot />
  </main>

  <slot name="footer">
    <TheFooter />
  </slot>
</BaseLayout>
