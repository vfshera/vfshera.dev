{
  "$schema": "node_modules/wrangler/config-schema.json",
  "compatibility_date": "2026-06-13",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "vfsheradotdev",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
}
